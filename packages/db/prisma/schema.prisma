generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String     @id @default(cuid())
  githubId      String?
  name          String?
  email         String?    @unique
  avatarUrl     String?
  stacksAddress String?   @unique
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  solutions     Solution[]
}

model Agent {
  id           String    @id @default(cuid())
  agentString  String    @unique
  createdAt    DateTime  @default(now())
  lastSeen     DateTime  @default(now())
  problems     Problem[]
  payments     Payment[]
}

model Problem {
  id              String   @id @default(cuid())
  agentId         String
  agent           Agent    @relation(fields: [agentId], references: [id])
  status          String   @default("open")
  errorType       String
  errorMessage    String
  fullQueryJson   String
  escrowTx        String?
  bountyAmount    String?
  urgency         String
  solutionId      String?
  solution        Solution? @relation(fields: [solutionId], references: [id])
  callbackUrl     String?
  queuedAgents    Int      @default(1)
  createdAt       DateTime @default(now())
  expiresAt       DateTime
  solveDeadline   DateTime?
}

model Solution {
  id                  String   @id @default(cuid())
  title               String
  authorId            String
  author              User     @relation(fields: [authorId], references: [id])
  structuredFixJson   String
  problemSignatures   String[] @default([])
  affectedStacks      String[] @default([])
  successRate         Float    @default(0.0)
  totalUses           Int      @default(0)
  priceUsdc           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  problems            Problem[]
}

model Payment {
  id         String   @id @default(cuid())
  txHash     String   @unique
  agentId    String
  agent      Agent    @relation(fields: [agentId], references: [id])
  solutionId String
  amountMicro Int
  currency   String   @default("USDCx")
  network    String   @default("stacks:testnet")
  status     String   @default("confirmed")
  createdAt  DateTime @default(now())
}
